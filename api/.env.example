# ==============================================
# RealEstateAR API — Environment Variables
# Copy this file to .env and fill in values
# ==============================================

# --- Server ---
API_PORT=3002
NODE_ENV=production

# --- MySQL ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=realestatear
DB_USER=realestatear-user
DB_PASSWORD=your_db_password_here

# --- JWT ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex
JWT_EXPIRES_IN=7d

# --- File Uploads ---
# Absolute path on VPS where GLB/image files are stored
UPLOAD_DIR=/var/www/realestatear/uploads
# Public base URL that maps to UPLOAD_DIR (served as static files)
UPLOAD_PUBLIC_URL=https://realestatear.dev.sbgroup.tech/uploads
